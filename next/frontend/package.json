{
  "name": "core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "generate:api": "orval --config orval.config.ts",
    "deploy": "netlify deploy --prod",
    "start": "next start -p 9000",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "tsc": "tsc --project tsconfig.json",
    "test": "mkdir -p .tmp && TMPDIR=$PWD/.tmp vitest run",
    "test:watch": "mkdir -p .tmp && TMPDIR=$PWD/.tmp vitest"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.9",
    "next": "^16.2.3",
    "query-string": "^9.3.1",
    "react": "19.2.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.1",
    "react-icons": "^5.5.0",
    "sass": "^1.94.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "24.3.3",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "jsdom": "^29.0.2",
    "orval": "^8.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
